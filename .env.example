# Financy — Configuration
# Copiez ce fichier en .env et adaptez les valeurs.

# Mot de passe d'accès (vide = pas d'authentification)
# FINANCY_PASSWORD=

# Clé secrète Flask pour les sessions (min. 32 car. ; générée aléatoirement si absente)
# SECRET_KEY=change-me-in-production

# Chemin vers la base de données (défaut : patrimoine.db dans le dossier du projet)
# DB_PATH=patrimoine.db

# Port du serveur (défaut : 5017)
# PORT=5017

# Durée de session en minutes (défaut : 60)
# SESSION_TIMEOUT_MINUTES=60

# Environnement (production désactive le debug et active Secure cookies)
# FLASK_ENV=production

# Provider de cours de marché (mock désactive tout appel réseau)
# Par défaut : yahoo. Utile pour tests / mode démo.
# PRICE_PROVIDER=yahoo

# Scheduler APScheduler — refresh quotidien automatique des cours
# (sinon refresh manuel uniquement via l'onglet Outils)
# SCHEDULER_ENABLED=false
# SCHEDULER_HOUR=21
# SCHEDULER_MINUTE=5
# SCHEDULER_TZ=Europe/Paris
