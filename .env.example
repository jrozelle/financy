# Financy — Configuration
# Copiez ce fichier en .env et adaptez les valeurs.

# Chemin vers la base de données (défaut : patrimoine.db dans le dossier du projet)
# DB_PATH=patrimoine.db

# Port du serveur (défaut : 5017)
# PORT=5017

# Mot de passe d'accès (vide = pas d'authentification)
# FINANCY_PASSWORD=

# Clé secrète Flask pour les sessions (générez une clé aléatoire en production)
# SECRET_KEY=change-me-in-production
